{
  "manifest_version": 3,
  "name": "JobCrawler",
  "version": "0.1.0",
  "description": "AI-powered job application automation",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://api.jobcrawler.app/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/search/*"],
      "js": ["dist/content/discovery-scraper.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/jobs/view/*"],
      "js": ["dist/content/job-page-scraper.js", "dist/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "JobCrawler"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
