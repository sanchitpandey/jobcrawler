DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/jobcrawler
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=replace-with-32-plus-random-chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

GROQ_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
TOGETHER_API_KEY=

# Dev: include all local ports the Vite dev server might use.
# Prod: only HTTPS origins. The production value should include your web app domain.
# Example dev value:
#   ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:5173"]
# Example prod value:
#   ALLOWED_ORIGINS=["https://jobcrawler.dev","https://www.jobcrawler.dev"]
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:5174","http://127.0.0.1:5173","http://127.0.0.1:5174"]

APP_ENV=development
DEBUG=false

# Email delivery (Resend — https://resend.com, free tier: 100 emails/day)
# Leave blank in local dev — verification codes will be logged as warnings instead.
RESEND_API_KEY=
# Dev/testing: use onboarding@resend.dev (no domain verification needed, delivers to your Resend account email only)
# Production: use your own verified domain, e.g. noreply@jobcrawler.dev (verify at resend.com/domains)
EMAIL_FROM=onboarding@resend.dev

# Sentry — leave blank to disable (safe for local dev)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
